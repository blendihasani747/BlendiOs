# BlendiOS Environment Configuration
# Copy this file to .env and adjust values for your environment.

# -----------------------------------------------------------------------------
# Core Paths
# -----------------------------------------------------------------------------
BLENDIOS_DATA_DIR=~/.blendios
BLENDIOS_DB_PATH=~/.blendios/system/blendios.db
BLENDIOS_VFS_PATH=~/.blendios/vfs
BLENDIOS_PLUGINS_PATH=~/.blendios/plugins
BLENDIOS_LOG_PATH=~/.blendios/system/logs

# -----------------------------------------------------------------------------
# API / Server
# -----------------------------------------------------------------------------
BLENDIOS_API_HOST=127.0.0.1
BLENDIOS_API_PORT=8000
BLENDIOS_API_PREFIX=/api/v1

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# IMPORTANT: Generate a strong secret key in production.
# Example: openssl rand -hex 32
BLENDIOS_SECRET_KEY=change-me-in-production
BLENDIOS_BCRYPT_ROUNDS=12
BLENDIOS_ACCESS_TOKEN_TTL_MINUTES=60
BLENDIOS_REFRESH_TOKEN_TTL_DAYS=7
BLENDIOS_MAX_FAILED_LOGINS=5
BLENDIOS_LOCKOUT_MINUTES=15

# -----------------------------------------------------------------------------
# Kernel Simulation
# -----------------------------------------------------------------------------
BLENDIOS_TOTAL_RAM_MB=4096
BLENDIOS_DEFAULT_SCHEDULER=round_robin
BLENDIOS_ROUND_ROBIN_QUANTUM_MS=100
BLENDIOS_ENABLE_ANIMATIONS=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
BLENDIOS_LOG_LEVEL=INFO
BLENDIOS_LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Desktop
# -----------------------------------------------------------------------------
BLENDIOS_DEFAULT_THEME=dark
BLENDIOS_DEFAULT_LANGUAGE=en
BLENDIOS_SCREEN_WIDTH=1920
BLENDIOS_SCREEN_HEIGHT=1080
